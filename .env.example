# Copy this file to ".env" and fill in your real key.
# .env is gitignored — your key must never be committed or shipped to the browser.

# Your Anthropic API key (server-side only, used by Netlify Functions).
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI API key — used for neural text-to-speech (ChatGPT-quality voice).
# Get one at https://platform.openai.com/api-keys
# Cost: ~$0.015 per 1,000 characters spoken (very cheap for normal use).
# If unset, the app falls back to the browser's built-in speech synthesis.
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the model. Defaults to claude-sonnet-4-6 if unset.
# Use a stronger model (e.g. claude-opus-4-8) for tougher marking if you have access.
CLAUDE_MODEL=claude-sonnet-4-6

# --- Cloud accounts (Supabase) — OPTIONAL ---
# When BOTH are set, GCSEase uses Supabase for cross-device accounts + progress.
# When unset, it falls back to on-device accounts (fine for local dev).
# These are exposed to the browser (VITE_ prefix); the anon key is safe to ship —
# it is protected by Row Level Security. NEVER put the service_role key here.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
