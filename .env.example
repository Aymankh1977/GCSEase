# Copy this file to ".env" and fill in your real key.
# .env is gitignored — your key must never be committed or shipped to the browser.

# Your Anthropic API key (server-side only, used by Netlify Functions).
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the model. Defaults to claude-sonnet-4-6 if unset.
# Use a stronger model (e.g. claude-opus-4-8) for tougher marking if you have access.
CLAUDE_MODEL=claude-sonnet-4-6
